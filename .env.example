# TerraQuant AI - Environment Variables
# Copy this file to .env and fill in your actual values

# Groq AI API Key (required for AI features)
EXPO_PUBLIC_GROQ_API_KEY=gsk_test_key_fake_example

# Groq Model Configuration
EXPO_PUBLIC_GROQ_MODEL=openai/gpt-oss-20b

# Backend Configuration
BACKEND_URL=http://127.0.0.1:8000

# Optional: Database Configuration
# DATABASE_URL=postgresql://user:password@localhost:5432/terraquant

# Optional: External APIs
# WEATHER_API_KEY=your_weather_api_key
# SATELLITE_API_KEY=your_satellite_api_key
